# Migration Configuration
# Copy this to .env.migration and fill in your values

# Server Configuration
NEW_SERVER_HOST=luke.nt.fh-koeln.de  # Domain/hostname for both SSH and Traefik
NEW_SERVER_USER=username              # SSH username

# Git Configuration (for cloning on new server)
GIT_REPO_URL=https://git-ce.rwth-aachen.de/ai4science/plant_biomass/2025_msc_felix_hagenbrock.git
GIT_USERNAME=your-username
GIT_PAT=your-personal-access-token

# Traefik Basic Auth (htpasswd format)
# Generate with: htpasswd -nb username password
# Example: admin:$apr1$xyz123$abc...
TRAEFIK_USER_ADMIN=admin:$apr1$...
TRAEFIK_USER_VIEWER=viewer:$apr1$...
